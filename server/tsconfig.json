{
    "compilerOptions": {
        "target": "ES2022",
        "module": "CommonJS",
        "moduleResolution": "Node",

        "rootDir": "src",
        "outDir": "dist",

        "baseUrl": ".",
        "paths": {
            "@/*": ["src/*"]
        },

        "strict": true,
        "esModuleInterop": true,
        "skipLibCheck": true
    },
    "include": ["src"]
}
